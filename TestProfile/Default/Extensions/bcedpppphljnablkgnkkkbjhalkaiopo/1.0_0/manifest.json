{
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "content.js" ],
      "matches": [ "https://m.kuku.lu/*" ],
      "run_at": "document_end"
   } ],
   "description": "テキストフィールドで右クリックするとメニューから｢期限付き捨てメールアドレスを生成｣ができます",
   "icons": {
      "128": "icon128.png",
      "16": "icon16.png",
      "19": "icon19.png",
      "32": "icon32.png",
      "38": "icon38.png",
      "48": "icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "捨てメアドジェネレーター",
   "permissions": [ "contextMenus", "activeTab", "clipboardWrite" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0"
}
