r"""
MoCKA Phase10
Audit writer with canonical DB path resolution.

Design goals:
- Single canonical DB path unless explicitly overridden.
- No implicit relative DB paths (knowledge.db default removed).
- Works in both modes:
  - python -m src.mocka_audit.audit_writer
  - python src/mocka_audit/audit_writer.py
"""

from __future__ import annotations

import json
import os
import sqlite3
import sys
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, Optional


def _ensure_project_root_on_syspath() -> None:
    """
    When executed as a file (python path/to/file.py), Python may not include the
    project root on sys.path, so 'import src....' can fail.
    This bootstrap makes both execution styles work.
    """
    try:
        __import__("src")
        return
    except Exception:
        pass

    # .../MoCKA/src/mocka_audit/audit_writer.py -> parents[2] == .../MoCKA
    project_root = Path(__file__).resolve().parents[2]
    pr_str = str(project_root)
    if pr_str not in sys.path:
        sys.path.insert(0, pr_str)


_ensure_project_root_on_syspath()

from src.mocka_audit.db_schema import LEDGER_TABLE, connect, ensure_audit_ledger_table  # noqa: E402


CANONICAL_DB_PATH = r"C:\Users\sirok\MoCKA\audit\ed25519\audit.db"
ENV_DB_PATH_KEY = "MOCKA_AUDIT_DB_PATH"


def resolve_audit_db_path(explicit_path: Optional[str] = None) -> str:
    """
    Resolution order:
    1) explicit_path argument (if provided)
    2) environment variable MOCKA_AUDIT_DB_PATH (if set)
    3) CANONICAL_DB_PATH
    """
    if explicit_path and str(explicit_path).strip():
        return str(explicit_path)

    env = os.environ.get(ENV_DB_PATH_KEY)
    if env and env.strip():
        return env

    return CANONICAL_DB_PATH


def _utc_now_iso() -> str:
    return datetime.now(timezone.utc).isoformat(timespec="seconds")


def _table_columns(conn: sqlite3.Connection, table: str) -> Dict[str, Dict[str, Any]]:
    cur = conn.execute(f"PRAGMA table_info({table});")
    cols: Dict[str, Dict[str, Any]] = {}
    for row in cur.fetchall():
        # row: (cid, name, type, notnull, dflt_value, pk)
        cols[str(row[1])] = {
            "cid": row[0],
            "name": row[1],
            "type": row[2],
            "notnull": row[3],
            "dflt_value": row[4],
            "pk": row[5],
        }
    return cols


def _insert_flexible(conn: sqlite3.Connection, table: str, candidate_values: Dict[str, Any]) -> None:
    cols = _table_columns(conn, table)
    usable = {k: v for k, v in candidate_values.items() if k in cols}
    if not usable:
        raise RuntimeError(f"No matching columns to insert into {table}")

    keys = list(usable.keys())
    placeholders = ",".join(["?"] * len(keys))
    sql = f"INSERT INTO {table} ({','.join(keys)}) VALUES ({placeholders});"
    conn.execute(sql, [usable[k] for k in keys])


@dataclass
class AuditWriter:
    audit_db_path: str

    def __init__(self, audit_db_path: Optional[str] = None) -> None:
        self.audit_db_path = resolve_audit_db_path(audit_db_path)

    def open(self) -> sqlite3.Connection:
        conn = connect(self.audit_db_path)
        ensure_audit_ledger_table(conn)
        return conn

    def write_event(self, event: Dict[str, Any], note: str = "", commit: bool = True) -> None:
        event_id = str(event.get("event_id", "")).strip()
        if not event_id:
            raise ValueError("event.event_id is required")

        created_at = str(event.get("created_at", "")).strip() or _utc_now_iso()
        prev_event_id = str(event.get("prev_event_id", "")).strip() or None
        chain_hash = str(event.get("chain_hash", "")).strip() or None

        payload_json = json.dumps(event, ensure_ascii=True, separators=(",", ":"))

        candidate = {
            "event_id": event_id,
            "created_at": created_at,
            "prev_event_id": prev_event_id,
            "chain_hash": chain_hash,
            "payload_json": payload_json,
            "note": note,
        }

        conn = self.open()
        try:
            _insert_flexible(conn, LEDGER_TABLE, candidate)
            if commit:
                conn.commit()
        finally:
            conn.close()


def main() -> None:
    db_path = resolve_audit_db_path()
    print("audit_db_path:", db_path)

    # NOTE(PHASE10): default is non-writing. Enable only when explicitly requested.
    if os.environ.get("MOCKA_TEST_WRITE", "") != "1":
        return

    writer = AuditWriter()
    test_event = {
        "event_id": "TEST_EVENT_DO_NOT_COMMIT",
        "prev_event_id": "GENESIS",
        "chain_hash": "0" * 64,
        "created_at": _utc_now_iso(),
        "kind": "test",
    }
    writer.write_event(test_event, note="phase10 test write", commit=True)
    print("OK: test event inserted")


if __name__ == "__main__":
    main()