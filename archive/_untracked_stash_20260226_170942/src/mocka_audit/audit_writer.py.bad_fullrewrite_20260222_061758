# src/mocka_audit/audit_writer.py
# Purpose:
# - Single writer for audit ledger (sqlite) and audit json artifacts (audit/<event_id>.json)
# - Guarantees DB NOT NULL constraints for event_id, chain_hash, event_content
#
# Notes:
# - This module intentionally prefers operational robustness over strict typing.

from __future__ import annotations

import os
import json
import sqlite3
import hashlib
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, List, Optional, Tuple


LEDGER_TABLE = "audit_ledger_event"
CONTRACT_VERSION = "mocka.audit.v1"


def _utc_now_iso() -> str:
    # Example: 2026-02-22T01:08:40.827407+00:00
    return datetime.now(timezone.utc).isoformat()


def _repo_root() -> Path:
    # .../MoCKA/src/mocka_audit/audit_writer.py -> parents[2] == .../MoCKA
    return Path(__file__).resolve().parents[2]


def _default_audit_db_path() -> Path:
    # Canonical path in this repo
    return _repo_root() / "audit" / "ed25519" / "audit.db"


def resolve_audit_db_path() -> str:
    v = os.environ.get("MOCKA_AUDIT_DB_PATH", "").strip()
    if v:
        return v
    return str(_default_audit_db_path())


def _audit_dir() -> Path:
    return _repo_root() / "audit"


def _sha256_hex(s: str) -> str:
    return hashlib.sha256(s.encode("utf-8")).hexdigest()


def _ensure_parent_dir(p: Path) -> None:
    p.parent.mkdir(parents=True, exist_ok=True)


def _ensure_schema(conn: sqlite3.Connection) -> None:
    # Make sure the table exists and includes event_content NOT NULL.
    conn.execute(
        f"""
        CREATE TABLE IF NOT EXISTS {LEDGER_TABLE} (
            event_id TEXT PRIMARY KEY NOT NULL,
            created_at TEXT NOT NULL,
            prev_event_id TEXT NULL,
            chain_hash TEXT NOT NULL,
            event_content TEXT NOT NULL,
            payload_json TEXT NOT NULL,
            note TEXT NOT NULL
        )
        """
    )
    # Helpful index for prev chain lookups
    conn.execute(f"CREATE INDEX IF NOT EXISTS idx_{LEDGER_TABLE}_prev ON {LEDGER_TABLE}(prev_event_id)")


def _table_columns(conn: sqlite3.Connection, table: str) -> List[str]:
    cur = conn.execute(f"PRAGMA table_info({table})")
    rows = cur.fetchall()
    # row: (cid, name, type, notnull, dflt_value, pk)
    return [r[1] for r in rows]


def _insert_flexible(conn: sqlite3.Connection, table: str, candidate: Dict[str, Any]) -> None:
    cols = _table_columns(conn, table)
    usable = {k: candidate[k] for k in candidate.keys() if k in cols}

    keys = list(usable.keys())
    if not keys:
        raise ValueError("No usable columns for insert")

    placeholders = ",".join(["?"] * len(keys))
    collist = ",".join(keys)
    sql = f"INSERT INTO {table} ({collist}) VALUES ({placeholders})"
    conn.execute(sql, [usable[k] for k in keys])


def _load_prev_chain_hash(conn: sqlite3.Connection, prev_event_id: str) -> Optional[str]:
    if not prev_event_id or prev_event_id == "GENESIS":
        return None
    cur = conn.execute(
        f"SELECT chain_hash FROM {LEDGER_TABLE} WHERE event_id = ? LIMIT 1",
        (prev_event_id,),
    )
    row = cur.fetchone()
    if not row:
        return None
    v = str(row[0]).strip()
    return v if v else None


def _compute_chain_hash(prev_chain_hash: Optional[str], event_id: str, prev_event_id: Optional[str]) -> str:
    # Keep this deterministic and simple.
    # If prev_chain_hash exists: sha256(prev_chain_hash + event_id)
    # Else: sha256((prev_event_id or 'GENESIS') + event_id)
    if prev_chain_hash:
        return _sha256_hex(prev_chain_hash + event_id)
    base = (prev_event_id or "GENESIS") + event_id
    return _sha256_hex(base)


def _write_audit_json(event: Dict[str, Any]) -> Path:
    # Normalize to the established on-disk contract (existing TIP files)
    out = {
        "event_content": event.get("event_content", ""),
        "event_id": event.get("event_id", ""),
        "prev_event_id": event.get("prev_event_id", None),
        "chain_hash": event.get("chain_hash", ""),
        "contract_version": CONTRACT_VERSION,
    }

    event_id = str(out["event_id"]).strip()
    if not event_id:
        raise ValueError("event_id missing for json write")

    p = _audit_dir() / f"{event_id}.json"
    _ensure_parent_dir(p)
    p.write_text(json.dumps(out, ensure_ascii=True, indent=2) + "\n", encoding="utf-8")
    return p


class AuditWriter:
    def __init__(self, db_path: Optional[str] = None) -> None:
        self._db_path = (db_path or resolve_audit_db_path()).strip()

    def open(self) -> sqlite3.Connection:
        _ensure_parent_dir(Path(self._db_path))
        conn = sqlite3.connect(self._db_path)
        _ensure_schema(conn)
        return conn

    def write_event(self, event: Dict[str, Any], note: str = "", commit: bool = True) -> None:
        # Required by callers / existing code path
        if not isinstance(event, dict):
            raise TypeError("event must be a dict")

        event_id = str(event.get("event_id", "")).strip()
        if not event_id:
            raise ValueError("event.event_id is required")

        created_at = str(event.get("created_at", "")).strip() or _utc_now_iso()

        prev_event_id_raw = event.get("prev_event_id", "")
        prev_event_id = str(prev_event_id_raw).strip() if prev_event_id_raw is not None else ""
        prev_event_id = prev_event_id or None

        # event_content must be NOT NULL in DB. If missing, fallback to payload_json later.
        event_content = str(event.get("event_content", "")).strip()

        # Persist full payload for auditability
        payload_json = json.dumps(event, ensure_ascii=True, separators=(",", ":"))

        # chain_hash must be NOT NULL in DB.
        chain_hash = str(event.get("chain_hash", "")).strip()

        conn = self.open()
        try:
            if not chain_hash:
                prev_chain_hash = _load_prev_chain_hash(conn, prev_event_id or "")
                chain_hash = _compute_chain_hash(prev_chain_hash, event_id, prev_event_id)

            # Enforce NOT NULL for event_content now
            if not event_content:
                event_content = payload_json

            candidate = {
                "event_id": event_id,
                "created_at": created_at,
                "prev_event_id": prev_event_id,
                "chain_hash": chain_hash,
                "event_content": event_content,
                "payload_json": payload_json,
                "note": str(note or ""),
            }

            _insert_flexible(conn, LEDGER_TABLE, candidate)

            if commit:
                conn.commit()
        finally:
            conn.close()

        # Also write canonical audit json artifact (file chain used by verify_chain_v2)
        # Keep the file schema aligned with existing audit/<event_id>.json.
        file_event = {
            "event_content": event_content,
            "event_id": event_id,
            "prev_event_id": prev_event_id,
            "chain_hash": chain_hash,
            "contract_version": CONTRACT_VERSION,
        }
        _write_audit_json(file_event)


def main() -> None:
    db_path = resolve_audit_db_path()
    print("audit_db_path:", db_path)

    # NOTE(PHASE10): default is non-writing. Enable only when explicitly requested.
    if os.environ.get("MOCKA_TEST_WRITE", "") != "1":
        return

    writer = AuditWriter()
    test_event = {
        "event_id": "TEST_EVENT_DO_NOT_COMMIT",
        "prev_event_id": "GENESIS",
        "event_content": _utc_now_iso(),
        # chain_hash intentionally omitted to test auto-compute
    }
    writer.write_event(test_event, note="test_write", commit=True)
    print("OK: wrote test event")


if __name__ == "__main__":
    main()
