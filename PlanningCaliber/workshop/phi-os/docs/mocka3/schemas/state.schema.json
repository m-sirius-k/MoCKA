{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InstitutionState",
  "description": "current_state.json の構造。Institution Domainの最新状態",
  "type": "object",
  "required": [
    "state_version", "project", "warnings", "todos",
    "decision_ledger_rev", "guideline_revision",
    "revision", "state_hash", "generated_at"
  ],
  "properties": {
    "state_version": {
      "type": "integer",
      "description": "Stateスキーマのバージョン"
    },
    "project": {
      "type": "object",
      "required": ["phase", "mission", "priority"],
      "properties": {
        "phase": { "type": "integer" },
        "mission": { "type": "string" },
        "priority": { "type": "array", "items": { "type": "string" } }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "level", "description"],
        "properties": {
          "id": { "type": "string" },
          "level": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "todos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "priority", "status"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "priority": { "type": "string" },
          "status": { "type": "string" }
        }
      }
    },
    "decision_ledger_rev": {
      "type": "integer",
      "description": "参照するDecision Ledgerのrevision"
    },
    "guideline_revision": {
      "type": "integer",
      "description": "参照するGuidelineのrevision"
    },
    "revision": {
      "type": "integer",
      "description": "Institution Stateのrevision。単調増加・巻き戻し不可"
    },
    "state_hash": {
      "type": "string",
      "description": "generated_atを除いた内容のSHA-256ハッシュ"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "State生成日時（ISO8601、UTC）"
    }
  }
}
