{
    "manifest_version":  3,
    "name":  "PHI OS",
    "version":  "1.0.0",
    "description":  "PHI OS - Persistent History Interface for claude.ai",
    "permissions":  [
                        "storage",
                        "tabs",
                        "sidePanel"
                    ],
    "host_permissions":  [
                             "https://claude.ai/*"
                         ],
    "background":  {
                       "service_worker":  "background.js"
                   },
    "action":  {
                   "default_popup":  "ui/options.html",
                   "default_icon":  {
                                        "16":  "icons/icon16.png",
                                        "48":  "icons/icon48.png",
                                        "128":  "icons/icon128.png"
                                    }
               },
    "options_ui":  {
                       "page":  "ui/options.html",
                       "open_in_tab":  true
                   },
    "side_panel":  {
                       "default_path":  "ui/sidepanel.html"
                   },
    "content_scripts":  [
                            {
                                "matches":  [
                                                "https://claude.ai/*"
                                            ],
                                "js":  [
                                           "content.js"
                                       ],
                                "run_at":  "document_idle"
                            }
                        ],
    "web_accessible_resources":  [
                                     {
                                         "resources":  [
                                                           "core/*.js",
                                                           "adapters/*.js",
                                                           "debug/*.js",
                                                           "ui/*.js"
                                                       ],
                                         "matches":  [
                                                         "https://claude.ai/*"
                                                     ]
                                     }
                                 ],
    "icons":  {
                  "16":  "icons/icon16.png",
                  "48":  "icons/icon48.png",
                  "128":  "icons/icon128.png"
              },
    "externally_connectable":  {
                                   "ids":  [
                                               "*"
                                           ],
                                   "matches":  [
                                                   "https://claude.ai/*"
                                               ]
                               }
}
