{
  "manifest_version": 3,
  "name": "Relay for Claude",
  "short_name": "Relay",
  "version": "2.0.0",
  "description": "Never lose your Claude context again. Auto-continue conversations, save decisions and next steps (Logbook), and inject past context into new chats (Vault - Pro).",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://claude.ai/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Relay for Claude"
  }
}
