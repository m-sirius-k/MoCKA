{
  "manifest_version": 3,
  "name": "Relay",
  "version": "4.1.0",
  "description": "Smart context handoff for Claude. Know when to switch, carry what matters.",
  "permissions": [
    "storage",
    "scripting",
    "webRequest",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "relay-utils.js",
        "content.js",
        "relay_search_ui.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
