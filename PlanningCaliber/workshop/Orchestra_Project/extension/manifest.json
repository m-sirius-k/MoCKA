{
  "manifest_version": 3,
  "name": "Orchestra",
  "version": "1.1.0",
  "description": "Automatically saves your AI conversations locally. No server. No tracking. 100% private.",
  "permissions": [
    "alarms",
    "storage",
    "tabs",
    "contextMenus",
    "scripting",
    "sidePanel",
    "identity",
    "identity.email"
  ],
  "oauth2": {
    "client_id": "399433086819-nt3hcjcpkrcfmbf705bk7lhdap8hdv9r.apps.googleusercontent.com",
    "scopes": ["openid", "email"]
  },
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://copilot.microsoft.com/*",
    "https://www.genspark.ai/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "content.js",
        "orchestra_search_bridge.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://www.genspark.ai/*"
      ],
      "js": [
        "content_orchestra.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icon_16.png",
      "48": "icon_48.png",
      "128": "icon_128.png"
    },
    "default_title": "Orchestra"
  },
  "icons": {
    "16": "icon_16.png",
    "48": "icon_48.png",
    "128": "icon_128.png"
  },
  "default_locale": "en",
  "side_panel": {
    "default_path": "popup.html"
  }
}